SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

WORKER_ID=local-worker-1
WORKER_POLL_SECONDS=5
WORKER_LEASE_SECONDS=300
WORKER_HEARTBEAT_SECONDS=30

# Hosted Immich
IMMICH_BASE_URL=https://your-immich-domain.example.com
IMMICH_API_KEY=your-immich-api-key
IMMICH_ADMIN_EMAIL=your-admin-email@example.com
IMMICH_ADMIN_PASSWORD=your-admin-password

# Upload queue rollout flag (set to "false" to hide local pending tiles UI)
NEXT_PUBLIC_ENABLE_LOCAL_UPLOAD_QUEUE=true
